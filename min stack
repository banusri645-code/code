class MinStack(object):

    def __init__(self):
        self.st=[]
    def push(self, val):
        if not self.st:
            self.st.append((val,val))
        else:
            current_min=min(val,self.st[-1][1])
            self.st.append((val,current_min))
    def pop(self):
        self.st.pop()
    def top(self):
        return self.st[-1][0]
    def getMin(self):
        return self.st[-1][1]
        


